{
  "name": "gd-tools",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/gd-tools/src",
  "targets": {
    "build": {
      "cache": true,
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/gd-tools"
      },
      "configurations": {
        "production": {
          "release": true
        }
      }
    },
    "build:linux": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run gd-tools:_build:linux",
          "nx run gd-tools:rename-binary --target=x86_64-unknown-linux-gnu"
        ]
      }
    },
    "_build:linux": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-unknown-linux-gnu",
        "target-dir": "dist/target/gd-tools",
        "release": true
      }
    },
    "build:windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run gd-tools:_build:windows",
          "nx run gd-tools:rename-binary --target=x86_64-pc-windows-gnu"
        ]
      }
    },
    "_build:windows": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-pc-windows-gnu",
        "target-dir": "dist/target/gd-tools",
        "release": true
      }
    },
    "build:macos": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run gd-tools:_build:macos",
          "nx run gd-tools:rename-binary --target=x86_64-apple-darwin"
        ]
      }
    },
    "_build:macos": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-apple-darwin",
        "target-dir": "dist/target/gd-tools",
        "release": true
      }
    },
    "rename-binary": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx scripts/rename-binary.ts dist/target/gd-tools {args.target}"
      }
    },
    "test": {
      "cache": true,
      "executor": "@monodon/rust:test",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/gd-tools"
      },
      "configurations": {
        "production": {
          "release": true
        }
      }
    },
    "lint": {
      "cache": true,
      "executor": "@monodon/rust:lint",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/gd-tools"
      }
    },
    "run": {
      "executor": "@monodon/rust:run",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/gd-tools"
      },
      "configurations": {
        "production": {
          "release": true
        }
      }
    }
  },
  "tags": []
}