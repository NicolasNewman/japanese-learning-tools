{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "linux",
    "platforms": [
        "linux"
    ],
    "description": "Capability for the main window on Linux",
    "windows": [
        "main"
    ],
    "permissions": [
        {
            "identifier": "fs:allow-exists",
            "allow": [
                {
                    "path": "$HOME/.mozilla"
                },
                {
                    "path": "$HOME/.mozilla/native-messaging-hosts"
                },
                {
                    "path": "$HOME/.mozilla/native-messaging-hosts/*"
                },
                {
                    "path": "$HOME/.config"
                },
                {
                    "path": "$HOME/.config/google-chrome"
                },
                {
                    "path": "$HOME/.config/google-chrome/NativeMessagingHosts"
                },
                {
                    "path": "$HOME/.config/google-chrome/NativeMessagingHosts/*"
                }
            ]
        },
        {
            "identifier": "fs:read-files",
            "allow": [
                {
                    "path": "$HOME/.mozilla/native-messaging-hosts/*"
                },
                {
                    "path": "$HOME/.config/google-chrome/NativeMessagingHosts/*"
                }
            ]
        },
        {
            "identifier": "fs:write-files",
            "allow": [
                {
                    "path": "$HOME/.mozilla/native-messaging-hosts/*"
                },
                {
                    "path": "$HOME/.config/google-chrome/NativeMessagingHosts/*"
                }
            ]
        },
        {
            "identifier": "fs:allow-mkdir",
            "allow": [
                {
                    "path": "$HOME/.mozilla"
                },
                {
                    "path": "$HOME/.mozilla/native-messaging-hosts"
                },
                {
                    "path": "$HOME/.config"
                },
                {
                    "path": "$HOME/.config/google-chrome"
                },
                {
                    "path": "$HOME/.config/google-chrome/NativeMessagingHosts"
                }
            ]
        }
    ]
}