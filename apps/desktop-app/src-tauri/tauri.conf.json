{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "desktop-app",
  "version": "0.1.0",
  "identifier": "com.nicolasnewman.jp-learning-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "desktop-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        "linux",
        "macos",
        "windows"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../gd-tools/resources/**/*": "resources/",
      "../../subs2clipboard-native-messenger/manifest/**/*": "resources/manifest",
      "../../../dist/target/mecab-ipadic-neologd/**/*": "resources/mecab-ipadic-neologd"
    },
    "externalBin": [
      "../../../dist/target/gd-tools/gd-tools",
      "../../../dist/target/subs2clipboard-native-messenger/subs2clipboard-native-messenger"
    ],
    "linux": {
      "rpm": {
        "compression": {
          "type": "xz",
          "level": 9
        }
      }
    }
  }
}