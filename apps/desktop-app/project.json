{
    "name": "desktop-app",
    "projectType": "application",
    "sourceRoot": "apps/desktop-app/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": [
                "{projectRoot}/build"
            ],
            "options": {
                "command": "cd {projectRoot} && pnpm tauri build -b deb",
                "cwd": "{workspaceRoot}"
            }
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "cd {projectRoot} && pnpm tauri dev",
                "cwd": "{workspaceRoot}"
            }
        }
    }
}