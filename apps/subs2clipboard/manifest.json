{
  "manifest_version": 2,
  "name": "JellyfinSubs2Clipboard",
  "version": "1.0",
  "description": "Automatically copies subtitles from Jellyfin to the clipboard",
  "icons": {
    "32": "icon-32.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"] ,
      "js": ["src/jellyfin-subs.ts"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "subs2clipboard@nicolasnewman.com",
      "strict_min_version": "50.0"
    }
  },
  "background": {
    "scripts": ["src/background.ts"]
  },
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging"
  ],
  "browser_action": {
    "default_icon": {
      "32": "icon-32.png"
    },
    "default_title": "JellyfinSubs2Clipboard"
  }
}