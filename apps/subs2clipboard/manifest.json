{
  "manifest_version": 2,
  "name": "Subs2Clipboard",
  "version": "1.6.0",
  "description": "Automatically copies subtitles from Jellyfin to the clipboard",
  "icons": {
    "32": "icon-32.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/jellyfin-subs.ts",
        "src/sudachi.ts",
        "src/content-debug.ts"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "subs2clipboard@nicolasnewman.com",
      "strict_min_version": "58.0"
    }
  },
  "background": {
    "scripts": [
      "src/background.ts"
    ]
  },
  "permissions": [
    "activeTab",
    "tabs",
    "nativeMessaging",
    "storage"
  ],
  "browser_action": {
    "default_icon": {
      "32": "icon-32.png"
    },
    "default_title": "Subs2Clipboard",
    "default_popup": "src/menu/index.html"
  }
}