{
    "name": "subs2clipboard",
    "projectType": "application",
    "sourceRoot": "apps/subs2clipboard/src",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": [
                "{projectRoot}/dist/subs2clipboard"
            ],
            "options": {
                "command": "cd {projectRoot} && pnpm vite build && web-ext build -s ../../dist/subs2clipboard -a ../../dist/",
                "cwd": "{workspaceRoot}"
            }
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "cd {projectRoot} && pnpm vite dev",
                "cwd": "{workspaceRoot}"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "options": {
                "lintFilePatterns": [
                    "{projectRoot}/src/**/*.ts",
                    "{projectRoot}/src/**/*.tsx",
                    "{projectRoot}/src/**/*.js",
                    "{projectRoot}/src/**/*.jsx"
                ]
            }
        }
    }
}