{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "windows",
  "platforms": [
    "windows"
  ],
  "description": "Capability for the main window on Windows",
  "windows": [
    "main"
  ],
  "permissions": [
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:read-files",
      "allow": [
        {
          "path": "$RESOURCE/**"
        },
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:write-files",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$APPDATA/**"
        }
      ]
    }
  ]
}