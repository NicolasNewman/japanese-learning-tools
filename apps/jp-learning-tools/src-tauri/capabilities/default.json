{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "os:default",
    "store:default",
    "fs:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$RESOURCE/resources/manifest/*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$RESOURCE/"
        }
      ]
    }
  ]
}