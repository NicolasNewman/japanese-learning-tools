{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "os:default",
    "store:default",
    "fs:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "cors-fetch:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "http://127.0.0.1:*"
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "$RESOURCE/resources/manifest/*"
        }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$RESOURCE/"
        },
        {
          "path": "$APPDATA/"
        }
      ]
    },
    "http:default"
  ]
}