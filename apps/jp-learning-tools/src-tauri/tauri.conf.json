{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jp-learning-tools",
  "version": "0.17.1",
  "identifier": "com.nicolasnewman.jp-learning-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "jp-learning-tools",
        "decorations": false,
        "width": 1000,
        "height": 800,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        "region-selector",
        "linux",
        "macos",
        "windows"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../gd-tools/resources/**/*": "resources/",
      "../../subs2clipboard-native-messenger/manifest/**/*": "resources/manifest",
      "../../../dist/target/mecab-ipadic-neologd/**/*": "resources/mecab-ipadic-neologd",
      "ocr/**/*": "resources/ocr",
      "lib/**/*": "",
      "../../../packages/mpv-scripts/mpvacious/mpvacious/": "resources/mpv/scripts/mpvacious/",
      "../../../packages/mpv-scripts/ModernX/modernx.lua": "resources/mpv/scripts/ModernX/main.lua",
      "../../../packages/mpv-scripts/script-opts/subs2srs.conf": "resources/mpv/scripts/script-opts/subs2srs.conf",
      "../../../packages/mpv-scripts/mpv.conf": "resources/mpv/mpv.conf",
      "../../../packages/mpv-scripts/ModernX/Material-Design-Iconic-Font.ttf": "resources/mpv/fonts/Material-Design-Iconic-Font.ttf"
    },
    "externalBin": [
      "../../../dist/target/gd-tools/gd-tools",
      "../../../dist/target/subs2clipboard-native-messenger/subs2clipboard-native-messenger",
      "../../../dist/target/gd-sudachi/gd-sudachi"
    ],
    "linux": {
      "rpm": {
        "compression": {
          "type": "none"
        }
      }
    },
    "windows": {
      "webviewInstallMode": {
        "silent": true,
        "type": "downloadBootstrapper"
      },
      "nsis": null,
      "wix": {
        "fragmentPaths": [
          "./windows/fragments/registry.wxs"
        ],
        "componentRefs": [
          "JPLearningToolsRegistryEntries"
        ]
      }
    }
  }
}