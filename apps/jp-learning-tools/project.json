{
    "name": "jp-learning-tools",
    "projectType": "application",
    "sourceRoot": "apps/jp-learning-tools/src",
    "targets": {
        "setup-deps": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx tauri-plugin-libmpv-api setup-lib",
                "cwd": "{workspaceRoot}"
            }
        },
        "build:linux": {
            "executor": "nx:run-commands",
            "outputs": [
                "{projectRoot}/build"
            ],
            "options": {
                "command": "cd {projectRoot} && pnpm tauri build -b deb,rpm",
                "cwd": "{workspaceRoot}"
            }
        },
        "build:windows": {
            "executor": "nx:run-commands",
            "outputs": [
                "{projectRoot}/build"
            ],
            "options": {
                "command": "cd {projectRoot} && pnpm tauri build -b msi",
                "cwd": "{workspaceRoot}"
            }
        },
        "dev": {
            "executor": "nx:run-commands",
            "options": {
                "command": "cd {projectRoot} && pnpm tauri dev",
                "cwd": "{workspaceRoot}"
            }
        }
    }
}