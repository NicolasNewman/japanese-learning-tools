{
  "name": "browser-native-messenger",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/browser-native-messenger/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run browser-native-messenger:build:linux",
          "nx run browser-native-messenger:build:windows"
        ],
        "parallel": false
      }
    },
    "build:linux": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run browser-native-messenger:_build:linux",
          "nx run browser-native-messenger:rename-binary --target=x86_64-unknown-linux-gnu"
        ],
        "parallel": false
      }
    },
    "_build:linux": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-unknown-linux-gnu",
        "target-dir": "dist/target/browser-native-messenger",
        "release": true
      }
    },
    "build:windows": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run browser-native-messenger:_build:windows",
          "nx run browser-native-messenger:rename-binary --target=x86_64-pc-windows-gnu"
        ],
        "parallel": false
      }
    },
    "_build:windows": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-pc-windows-gnu",
        "target-dir": "dist/target/browser-native-messenger",
        "release": true
      }
    },
    "build:macos": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run browser-native-messenger:_build:macos",
          "nx run browser-native-messenger:rename-binary --target=x86_64-apple-darwin"
        ],
        "parallel": false
      }
    },
    "_build:macos": {
      "executor": "@monodon/rust:build",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target": "x86_64-apple-darwin",
        "target-dir": "dist/target/browser-native-messenger",
        "release": true
      }
    },
    "rename-binary": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx scripts/rename-binary.ts dist/target/browser-native-messenger {args.target}"
      }
    },
    "test": {
      "cache": true,
      "executor": "@monodon/rust:test",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/browser-native-messenger"
      },
      "configurations": {
        "production": {
          "release": true
        }
      }
    },
    "lint": {
      "cache": true,
      "executor": "@monodon/rust:lint",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/browser-native-messenger"
      }
    },
    "run": {
      "executor": "@monodon/rust:run",
      "outputs": [
        "{options.target-dir}"
      ],
      "options": {
        "target-dir": "dist/target/browser-native-messenger"
      },
      "configurations": {
        "production": {
          "release": true
        }
      }
    }
  },
  "tags": []
}