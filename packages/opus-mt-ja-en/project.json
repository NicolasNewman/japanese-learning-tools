{
  "name": "opus-mt-ja-en",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "opus-mt-ja-en/opus_mt_ja_en",
  "targets": {
    "lock": {
      "executor": "@nxlv/python:lock",
      "options": {
        "update": false
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd {projectRoot} && poetry run python -m opus_mt_ja_en.convert_slow_tokenizer"
      }
    },
    "install": {
      "executor": "@nxlv/python:install",
      "options": {
        "silent": false,
        "args": "",
        "cacheDir": ".cache/pypoetry",
        "verbose": false,
        "debug": false
      }
    }
  },
  "tags": [],
  "release": {
    "version": {
      "generator": "@nxlv/python:release-version"
    }
  }
}
