{
  "name": "@nicolasnewman/jp-learning-tools",
  "version": "0.17.0",
  "license": "MIT",
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "commitlint": "commitlint --edit",
    "prepare": "husky install",
    "dev:tauri": "nx run jp-learning-tools:dev",
    "dev:ext": "nx run subs2clipboard:dev",
    "build": "pnpm run build:ext && pnpm run build:gd-tools && pnpm run build:dic && pnpm run build:tauri",
    "build:ext": "nx run subs2clipboard-native-messenger:build",
    "build:tauri": "nx run jp-learning-tools:build",
    "build:gd-tools": "nx run gd-tools:build",
    "build:dic": "nx run mecab-ipadic-neologd:build",
    "build:linux": "mkdir -p ./dist/target && nx run mecab-ipadic-neologd:build --tuiAutoExit && nx run gd-tools:build:linux --tuiAutoExit && nx run gd-sudachi:build:linux --tuiAutoExit && nx run subs2clipboard-native-messenger:build:linux --tuiAutoExit && nx run jp-learning-tools:build:linux",
    "build:android": "nx run kanji-scanner:build-apk",
    "build:ios": "nx run kanji-scanner:build-ios",
    "act:release": "act pull_request -e act/pr-event.json --artifact-server-path ./.act-artifacts",
    "act:release:windows": "act pull_request -P windows-latest=-self-hosted -e act/pr-event.json --artifact-server-path ./.act-artifacts"
  },
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/config-nx-scopes": "^19.8.1",
    "@monodon/rust": "^2.3.0",
    "@nx/eslint": "22.7.0",
    "@nx/eslint-plugin": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/vite": "22.7.0",
    "@nx/web": "22.7.0",
    "@nxlv/python": "^22.1.3",
    "@nxrocks/nx-flutter": "^10.0.1",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@types/node": "18.16.9",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/ui": "^3.0.0",
    "eslint": "~8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.7.0",
    "prettier": "^2.6.2",
    "swc-loader": "0.1.15",
    "tslib": "^2.3.0",
    "tsx": "^4.20.3",
    "typescript": "~5.7.2",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "web-ext": "^8.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}